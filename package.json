{
  "name": "persian-content-calendar",
  "version": "2.0.0",
  "description": "A Persian (Jalali) content calendar with backend for managing Instagram and website content",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend-only": "npx live-server --port=3000 --open=/public/index.html",
    "serve": "npx http-server public -p 8080 -o"
  },
  "keywords": [
    "calendar",
    "persian",
    "jalali",
    "content-calendar",
    "instagram",
    "content-management",
    "rtl",
    "backend",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "live-server": "^1.2.2",
    "serve": "^14.2.0"
  }
}